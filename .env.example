# Atlas environment configuration.
# Copy this file to backend/.env for local development:  cp .env.example backend/.env
# (pydantic-settings loads `.env` relative to the process cwd, which is backend/ in dev.)
# Never commit a real .env — only this example with dummy values.

# --- LLM provider (OpenAI is the sole provider) ---
OPENAI_API_KEY=sk-dummy-openai-key
# Default chat model, provider-prefixed for LangChain's init_chat_model.
# Also the per-role fallback when a role is omitted from MODEL_ROUTING.
DEFAULT_MODEL=openai:gpt-4o-mini
# Role -> model routing (F9), JSON object of provider-prefixed init_chat_model ids.
# OpenAI-only (§3). Optional — omit to use the built-in default below; omitted roles
# fall back to DEFAULT_MODEL. Strong tier = gpt-4o, cheap tier = gpt-4o-mini.
# MODEL_ROUTING={"planner":"openai:gpt-4o","reviewer":"openai:gpt-4o","writer":"openai:gpt-4o","worker":"openai:gpt-4o-mini"}

# --- Web search tool ---
TAVILY_API_KEY=tvly-dummy-tavily-key

# --- Evaluation harness (F8) ---
# LLM-as-judge models for the coverage/groundedness graders (provider-prefixed).
# EVAL_JUDGE_MODEL is the strong default; EVAL_SMOKE_MODEL is the cheap judge
# used by `run_benchmark.py --smoke`.
EVAL_JUDGE_MODEL=openai:gpt-4o
EVAL_SMOKE_MODEL=openai:gpt-4o-mini

# --- RAG retriever tool (optional) ---
# Base URL of your existing RAG service. Leave unset to disable the rag_search
# tool entirely — the graph runs fine without it.
# RAG_SERVICE_URL=http://localhost:8100

# --- Observability (LangSmith) ---
LANGSMITH_API_KEY=ls-dummy-langsmith-key
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=atlas

# --- Database (must match docker-compose.yml credentials) ---
DATABASE_URL=postgresql://atlas:atlas@localhost:5432/atlas

# --- Checkpointer backend: "sqlite" (dev) | "postgres" (prod) ---
CHECKPOINT_BACKEND=sqlite

# --- CORS: comma-separated list of allowed origins ---
CORS_ORIGINS=http://localhost:5173
