# Base URL for the Atlas API. Empty = same-origin (the Vite dev proxy forwards /api →
# http://localhost:8000, so no value is needed for local dev). In production (F13) set
# this to the API origin, e.g. https://atlas.example.com
VITE_API_URL=

# LangSmith project URL (path up to the project) used to deep-link a run's trace from
# the RunPage error banner: the link is `${VITE_LANGSMITH_BASE_URL}/r/${trace_id}`.
# Empty = the "View trace in LangSmith" link falls back to the LangSmith home (never a
# dead link). Example: https://smith.langchain.com/o/<org-id>/projects/p/<project-id>
VITE_LANGSMITH_BASE_URL=
